  productId       String          @db.Uuid
  buyerId         String          @db.Uuid
  orderId         String          @unique @db.Uuid
  users           users           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  uniMartOrder    uniMartOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uniMartProducts uniMartProducts @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([productId])
}

