model uniMartReview {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rating    Int             @db.SmallInt
  comment   String
  createdAt DateTime        @default(now()) @db.Timestamp(6)
  updatedAt DateTime        @updatedAt
  productId String          @db.Uuid
  buyerId   String          @db.Uuid
  orderId   String          @unique @db.Uuid
  buyer     users           @relation("uniMartReviews", fields: [buyerId], references: [id], onDelete: Cascade)
  order     uniMartOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   uniMartProducts @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
  @@map("unimart_reviews")
}

model user_skills {
